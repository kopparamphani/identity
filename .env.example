# Identity service config. Copy to .env for local dev. NEVER commit a real .env.
# In prod these come from Sealed Secrets (ADR-0018), not a file.

# Postgres connection (database-per-service, ADR-0006).
DATABASE_URL=postgres://postgres:dev@localhost:5432/identity

# Signs the short-lived access-token JWT (ADR-0024). Use a long random value.
JWT_SECRET=change-me-to-a-long-random-string

# local | production. Controls Secure cookie flag (Secure on in production).
NODE_ENV=development

# HTTP port the service listens on.
PORT=3000
