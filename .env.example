# Identity service config. Copy to .env for local dev. NEVER commit a real .env.
# In prod these come from Sealed Secrets (ADR-0018), not a file.

# Postgres connection (database-per-service, ADR-0006).
DATABASE_URL=postgres://postgres:dev@localhost:5432/identity

# Signs the short-lived access-token JWT (ADR-0024). Use a long random value.
JWT_SECRET=change-me-to-a-long-random-string

# local | production. Controls Secure cookie flag (Secure on in production).
NODE_ENV=development

# HTTP port the service listens on.
PORT=3000

# Google OAuth client id (1b Google sign-in). Verifies the ID token's audience.
# No client SECRET needed for ID-token verification. Required for /auth/google.
# In prod this comes from Sealed Secrets (ADR-0018), not a file.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Forgotten-password reset (1c). The reset email is sent over SMTP.
# Local dev: run Mailpit (catch-all inbox) -> SMTP on localhost:1025, web UI 8025.
#   docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
# PROD SMTP host + credentials are a deploy-time secret (Sealed Secrets, ADR-0018).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@expense-tracker.local

# Base URL of the web app the reset link points at: ${APP_BASE_URL}/reset?token=...
APP_BASE_URL=http://localhost:5173
